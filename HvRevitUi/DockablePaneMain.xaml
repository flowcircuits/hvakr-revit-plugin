<UserControl x:Class="HvRevitUi.DockablePaneMain"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="300"
             FontFamily="Segoe UI"
             FontSize="12"
             Foreground="#FFF5F5F5"
             Background="#FF3B4453">

    <UserControl.Resources>
        <!-- TextBox style: no visible border until focused; min width 110; left-aligned text -->
        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FF3B4453"/>
            <Setter Property="Foreground" Value="#FFF5F5F5"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#FF485263"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBox style: mimics TextBox look with dark background, white text, thin 1px border -->
        <Style x:Key="DarkComboBoxStyle"
       TargetType="ComboBox"
       BasedOn="{StaticResource {x:Type ComboBox}}">

            <!-- Dark background, light text, etc. -->
            <!-- <Setter Property="Background" Value="#FF3B4453"/> -->
            <!-- <Setter Property="Foreground" Value="#FFF5F5F5"/> -->
            <!-- <Setter Property="Foreground" Value="#FF3B4453"/> -->
            <Setter Property="BorderBrush" Value="#FF485263"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <!-- Button style: dark background, light text, 1px border -->
        <Style TargetType="Button">
            <Setter Property="Width" Value="75"/>
            <Setter Property="Background" Value="#FF485263"/>
            <Setter Property="Foreground" Value="#FFF5F5F5"/>
            <Setter Property="BorderBrush" Value="#FF485263"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
        </Style>
    </UserControl.Resources>

    <!-- Outer border for visual separation -->
    <Border BorderBrush="#FF485263" BorderThickness="1"
            Background="{Binding Background, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <Grid>
            <!-- Three rows:
                 Row 0: API Key section (API key and Login button)
                 Row 1: Separator
                 Row 2: Details section (Project, Address, Offsets) -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition />
            </Grid.RowDefinitions>

            <!-- API Key Section -->
            <StackPanel Grid.Row="0" Margin="10,10,10,0">
                <!-- API Key row: Grid with three columns: label, vertical line, input -->
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="API key" Grid.Column="0" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Width="1" Background="#FF485263" Margin="5,0"/>
                    <TextBox Grid.Column="2" x:Name="TextBoxApiKey" Text="Edit..." GotFocus="TextBoxApiKey_GotFocus" />
                </Grid>
                <Border Height="1" Background="#FF485263" Margin="0,0,0,2"/>
                <!-- Login button row: Grid with same columns; button placed in input column -->
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Login Button -->
                    <Button Grid.Column="0" Content="Login" Click="LoginButton_Click" x:Name="ButtonLogin" Margin="0,0,0,0" Width="NaN"/>
                </Grid>
            </StackPanel>

            <!-- Separator between API Key section and Details -->
            <Border Grid.Row="1" Height="1" Background="#FF485263" Margin="10,10,10,10"/>

            <!-- Details Section: disabled until login -->
            <StackPanel Grid.Row="2" Margin="10,0,10,0" IsEnabled="False" x:Name="DetailsPanel">
                <!-- Project row -->
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Project" Grid.Column="0" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Width="1" Background="#FF485263" Margin="5,0"/>
                    <ComboBox Grid.Column="2" x:Name="ComboBoxProject" Style="{StaticResource DarkComboBoxStyle}" IsEditable="False" SelectionChanged="ComboBoxProject_SelectionChanged" DisplayMemberPath="Name">
                    </ComboBox>
                </Grid>

                <!-- Horizontal separator between Project and Address rows -->
                <Border Height="1" Background="#FF485263" Margin="0,0,0,2"/>

                <!-- Address row -->
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Address" Grid.Column="0" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Width="1" Background="#FF485263" Margin="5,0"/>
                    <!-- Display-only field: simple TextBlock with blank text -->
                    <TextBlock Grid.Column="2" Text="" VerticalAlignment="Center" Padding="2" x:Name="TextBlockAddress"/>
                </Grid>

                <!-- Horizontal separator between Address and Offset rows -->
                <Border Height="1" Background="#FF485263" Margin="0,0,0,2"/>

                <!-- Offset X row -->
                <!--
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Offset X" Grid.Column="0" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Width="1" Background="#FF485263" Margin="5,0"/>
                    <TextBox Grid.Column="2" Text="" x:Name="TextBoxOffsetX" GotFocus="TextBoxOffset_GotFocus" LostFocus="TextBoxOffset_LostFocus"  KeyDown="TextBoxOffset_KeyDown"/>
                </Grid>
                <Border Height="1" Background="#FF485263" Margin="0,0,0,2"/>
                -->
                <!-- Offset Y row -->
                <!--
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Offset Y" Grid.Column="0" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Width="1" Background="#FF485263" Margin="5,0"/>
                    <TextBox Grid.Column="2" Text="" x:Name="TextBoxOffsetY" GotFocus="TextBoxOffset_GotFocus" LostFocus="TextBoxOffset_LostFocus" KeyDown="TextBoxOffset_KeyDown"/>
                </Grid>
                <Border Height="1" Background="#FF485263" Margin="0,0,0,2"/>
                -->
                <!-- Offset Z row -->
                <!--
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Offset Z" Grid.Column="0" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Width="1" Background="#FF485263" Margin="5,0"/>
                    <TextBox Grid.Column="2" Text="" x:Name="TextBoxOffsetZ" GotFocus="TextBoxOffset_GotFocus" LostFocus="TextBoxOffset_LostFocus" KeyDown="TextBoxOffset_KeyDown"/>
                </Grid>
                <Border Height="1" Background="#FF485263" Margin="0,0,0,2"/>
                -->

                <!-- Add HVAKR Spaces to Revit button -->
                <!-- TODO: Add this back in once we can focus on HVAKR to Revit sync
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Add HVAKR Spaces to Revit" Click="AddHVAKRSpacesToRevitButton_Click" x:Name="ButtonAddHVAKRSpacesToRevit" Margin="0,0,0,0" Width="NaN"/>
                </Grid>
                -->

                <!-- Export to Selected Project button -->
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Export to Selected Project" Click="ExportToSelectedProjectButton_Click" x:Name="ButtonExportToSelectedProject" Margin="0,0,0,0" Width="NaN"/>
                </Grid>

                <Border Height="1" Background="#FF485263" Margin="0,10,0,10"/>
                
                <!-- Create HVAKR Project button -->
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Create New HVAKR Project" Click="CreateHVAKRProjectButton_Click" x:Name="ButtonCreateHVAKRProject" Margin="0,0,0,0" Width="NaN"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
