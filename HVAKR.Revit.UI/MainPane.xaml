<UserControl x:Class="HVAKR.Revit.UI.MainPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="300"
             FontFamily="Segoe UI"
             FontSize="12"
             Foreground="#FFF5F5F5"
             Background="#FF3B4453">

    <UserControl.Resources>
        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FF3B4453"/>
            <Setter Property="Foreground" Value="#FFF5F5F5"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#FF485263"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FF3B4453"/>
            <Setter Property="Foreground" Value="#FFF5F5F5"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#FF485263"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="BorderBrush" Value="#FF485263"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Width" Value="75"/>
            <Setter Property="Background" Value="#FF485263"/>
            <Setter Property="Foreground" Value="#FFF5F5F5"/>
            <Setter Property="BorderBrush" Value="#FF485263"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
        </Style>
    </UserControl.Resources>

    <Border BorderBrush="#FF485263" BorderThickness="1"
            Background="{Binding Background, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition />
            </Grid.RowDefinitions>

            <!-- Login section -->
            <StackPanel Grid.Row="0" Margin="10,10,10,0">
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="API key" Grid.Column="0" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Width="1" Background="#FF485263" Margin="5,0"/>
                    <PasswordBox Grid.Column="2" x:Name="ApiKeyBox"/>
                </Grid>
                <Border Height="1" Background="#FF485263" Margin="0,0,0,2"/>
                <Button Content="Login" Click="LoginButton_Click" x:Name="LoginButton" Margin="0" Width="NaN" HorizontalAlignment="Stretch"/>
            </StackPanel>

            <Border Grid.Row="1" Height="1" Background="#FF485263" Margin="10,10,10,10"/>

            <!-- Project details — disabled until login -->
            <StackPanel Grid.Row="2" Margin="10,0,10,0" IsEnabled="False" x:Name="DetailsPanel">
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Project" Grid.Column="0" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Width="1" Background="#FF485263" Margin="5,0"/>
                    <ComboBox Grid.Column="2" x:Name="ProjectPicker"
                              Style="{StaticResource DarkComboBoxStyle}"
                              IsEditable="False"
                              SelectionChanged="ProjectPicker_SelectionChanged"
                              DisplayMemberPath="Name"/>
                </Grid>

                <Border Height="1" Background="#FF485263" Margin="0,0,0,2"/>

                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Address" Grid.Column="0" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Width="1" Background="#FF485263" Margin="5,0"/>
                    <TextBlock Grid.Column="2" Text="" VerticalAlignment="Center" Padding="2" x:Name="AddressLabel"/>
                </Grid>

                <Border Height="1" Background="#FF485263" Margin="0,0,0,2"/>

                <Button Content="Export to Selected Project"
                        Click="ExportButton_Click"
                        x:Name="ExportButton"
                        Margin="0" Width="NaN" HorizontalAlignment="Stretch"/>

                <Border Height="1" Background="#FF485263" Margin="0,10,0,10"/>

                <Button Content="Create New HVAKR Project"
                        Click="CreateProjectButton_Click"
                        x:Name="CreateProjectButton"
                        Margin="0" Width="NaN" HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
